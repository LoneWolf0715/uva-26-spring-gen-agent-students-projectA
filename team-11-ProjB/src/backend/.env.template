# Copy to .env and adjust. See README for descriptions.

# Ollama (required for LLM calls)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4
# Per-request HTTP timeout in seconds (large reports on slow hardware may need more).
OLLAMA_TIMEOUT_SEC=600

# Optional APIs
# BRAVE_SEARCH_API_KEY=
# FINANCIAL_API_KEY=

# Comma-separated list is not supported — use JSON for multiple origins, e.g.:
# CORS_ORIGINS=["http://localhost:3000","https://your-frontend.example.com"]

# Server (used by run.py)
# PORT=8000
# FINSYNTH_RELOAD=0
